#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"; valid(){ [[ "$1" =~ ^[1-4]$ ]] || exit 2; }
case "${1:-status}" in
 install) sudo install -m0644 "$ROOT/systemd/ota-ui@.service" /etc/systemd/system/ota-ui@.service; sudo install -m0644 "$ROOT/systemd/ota-worker@.service" /etc/systemd/system/ota-worker@.service; sudo systemctl daemon-reload;;
 start-ui|stop-ui|restart-ui) valid "$2"; sudo systemctl "$1" "ota-ui@$2.service";;
 start-worker|stop-worker|restart-worker) valid "$2"; action="${1%%-worker}"; sudo systemctl "$action" "ota-worker@$2.service";;
 start-all-uis) for i in 1 2 3 4; do sudo systemctl start ota-ui@$i.service; done;;
 stop-all-uis) for i in 1 2 3 4; do sudo systemctl stop ota-ui@$i.service; done;;
 status) sudo systemctl --no-pager --full status 'ota-ui@*.service' 'ota-worker@*.service' || true;;
 logs-ui) valid "$2"; sudo journalctl -u ota-ui@$2.service -n 120 --no-pager;;
 logs-worker) valid "$2"; sudo journalctl -u ota-worker@$2.service -n 120 --no-pager;;
 *) echo 'usage: ota-services install|start-ui N|stop-ui N|restart-ui N|start-worker N|stop-worker N|restart-worker N|start-all-uis|stop-all-uis|status|logs-ui N|logs-worker N'; exit 2;;
esac
