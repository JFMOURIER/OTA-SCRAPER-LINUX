INSTANCE_ID=instance_1
INSTANCE_NAME=Instance 1
INSTANCE_PORT=8501
INSTANCE_DATA_DIR=data/instances/instance_1
INSTANCE_START_DATE=2026-08-01
INSTANCE_END_DATE=2026-08-31
INSTANCE_CITY=Orlando
INSTANCE_SOURCE=Booking.com

# Local SQLite is the default and needs no server.
DB_BACKEND=sqlite

# Conservative defaults for the 8 GB scraper tower.
OTA_MIN_START_AVAILABLE_MB=800
OTA_EMERGENCY_AVAILABLE_MB=500
OTA_MIN_SWAP_FREE_MB=256
OTA_MAX_SWAP_PERCENT=94
OTA_WARN_PYTHON_RSS_MB=1600
OTA_STOP_PYTHON_RSS_MB=2400
OTA_WARN_BROWSER_RSS_MB=1800
OTA_STOP_BROWSER_RSS_MB=2600
OTA_MIN_DISK_FREE_GB=5
OTA_SCREENSHOT_LIMIT_PER_DATE=12

# Optional PostgreSQL settings if you choose DB_BACKEND=postgres.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hotel_price_collector
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Optional API provider credentials.
SERPAPI_API_KEY=
SEARCHAPI_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
EXPEDIA_RAPID_API_KEY=
